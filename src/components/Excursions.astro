---
import { getCollection, getEntry } from 'astro:content';
import WavePattern from './WavePattern.astro';

const header = await getEntry('sections', 'excursions-header');
const h = header.data;

const all = await getCollection('excursions', ({ data }) => data.published);
const items = all.sort((a, b) => a.data.order - b.data.order);

// Replace headlineEm phrase with <em>headlineEm</em> in headline
const headlineParts = h.headline.split(h.headlineEm);
---
<section class="excursions" id="excursions">
  <WavePattern />
  <div class="container">
    <div class="section-header">
      <div class="section-header-tag">{h.chapterLabel}<span>{h.chapterSubtitle}</span></div>
      <h2>{headlineParts[0]}<em>{h.headlineEm}</em>{headlineParts.slice(1).join(h.headlineEm)}</h2>
    </div>
    <p class="lede">{h.lede}</p>

    <div class="exc-grid">
      {items.map(({ data: e }) => (
        <article class="exc-card">
          <div class="exc-img">
            <img src={e.image} alt={e.imageAlt} />
            <div class="exc-distance">{e.distance}</div>
          </div>
          <div class="exc-body">
            <div class="exc-cat">{e.category}</div>
            <h3>{e.name} <em>{e.nameEm}</em></h3>
            <p>{e.description}</p>
          </div>
        </article>
      ))}
    </div>

    <p class="exc-cta">{h.ctaText}</p>
  </div>
</section>
