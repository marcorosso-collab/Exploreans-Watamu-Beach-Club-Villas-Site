---
import { getEntry } from 'astro:content';
import RichText from './RichText.astro';
import WavePattern from './WavePattern.astro';

const entry = await getEntry('sections', 'family');
const d = entry.data;
if (d.type !== 'family') throw new Error('Expected family section');
---
<section class="family">
  <WavePattern />
  <div class="container">
    <div class="eyebrow" style="margin-bottom: 1.5rem;">{d.eyebrow}</div>
    <RichText text={d.headline} as="h2" />
    <p>{d.lede}</p>

    <div class="pillars">
      {d.pillars.map(p => <span>{p}</span>)}
    </div>

    <div class="family-brands">
      {d.brands.map(b => (
        <a href={b.url} target="_blank" rel="noopener" class="brand-card">
          <div class="brand-card-logo">
            <img src={b.logo} alt={`${b.name} Logo`} />
          </div>
          <p>{b.description}</p>
          <span class="brand-card-link">Visit {b.name} →</span>
        </a>
      ))}
    </div>
  </div>
</section>
