---
import { getCollection, getEntry } from 'astro:content';

const header = await getEntry('sections', 'notes-header');
const h = header.data;

// Try to get posts first, fallback to notes for backward compatibility
const allPosts = await getCollection('posts', ({ data }) => data.published);
const allNotes = await getCollection('notes', ({ data }) => data.published);

// Use posts if available, otherwise fall back to notes
const hasPosts = allPosts.length > 0;
const items = hasPosts 
  ? allPosts.sort((a, b) => a.data.order - b.data.order).slice(0, 3)
  : allNotes.sort((a, b) => a.data.order - b.data.order);

// Replace headlineEm phrase with <em>headlineEm</em> in headline
const headlineParts = h.headline.split(h.headlineEm);
---
<section class="notes" id="notes">
  <div class="container">
    <div class="section-header">
      <div class="section-header-tag">{h.sectionLabel}<span>{h.sectionSubtitle}</span></div>
      <h2>{headlineParts[0]}<em>{h.headlineEm}</em>{headlineParts.slice(1).join(h.headlineEm)}</h2>
    </div>

    <div class="notes-grid">
      {items.map((item) => {
        const n = item.data;
        const isPost = 'metaTitle' in n; // posts have metaTitle, notes don't
        const href = isPost ? `/notes/${item.slug}` : (n.link || '#');
        const title = n.title;
        const titleEm = n.titleEm || '';
        const excerpt = isPost ? n.excerpt : n.excerpt;
        const image = n.image;
        const imageAlt = n.imageAlt;
        const noteNumber = isPost ? `Field Note · No. ${String(n.order).padStart(2, '0')}` : n.noteNumber;
        
        return (
          <article class="note">
            <a href={href} class="note-link">
              <div class="note-img">
                <img src={image} alt={imageAlt} />
              </div>
            </a>
            <div class="note-meta">{noteNumber}</div>
            <h3>{title} <em>{titleEm}</em></h3>
            <p>{excerpt}</p>
            <a href={href} class="note-read-more">
              {isPost ? 'Read the full story' : 'Read the entry'}
              {isPost && <span class="note-read-time">→</span>}
            </a>
          </article>
        );
      })}
    </div>

    {hasPosts && allPosts.length > 3 && (
      <div class="notes-archive-link">
        <a href="/notes" class="btn">View all field notes</a>
      </div>
    )}
  </div>
</section>
