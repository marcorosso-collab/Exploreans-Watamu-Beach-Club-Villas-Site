---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.published);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const p = post.data;
const { Content } = await post.render();

// Get site settings for structured data
const siteEntry = await getEntry('site', 'settings');
const site = siteEntry?.data;
const s = site;

// Get related posts
const relatedPosts = [];
for (const relatedSlug of p.relatedPosts || []) {
  try {
    const related = await getEntry('posts', relatedSlug);
    if (related && related.data.published) {
      relatedPosts.push(related);
    }
  } catch (e) { /* ignore missing */ }
}

// Build title with brand
const pageTitle = p.metaTitle || `${p.title}${p.titleEm ? ` ${p.titleEm}` : ''} | ${site?.siteName || 'Exploreans'}`;

// JSON-LD structured data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: p.title + (p.titleEm ? ` ${p.titleEm}` : ''),
  description: p.metaDescription,
  image: p.ogImage || p.image,
  datePublished: p.publishDate,
  dateModified: p.updatedDate || p.publishDate,
  author: {
    '@type': 'Organization',
    name: p.author
  },
  publisher: {
    '@type': 'Organization',
    name: site?.siteName || 'Exploreans',
    logo: {
      '@type': 'ImageObject',
      url: site?.url ? `${site.url}/images/logo.png` : undefined
    }
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': p.canonicalUrl || `${site?.url || ''}/notes/${post.slug}`
  },
  keywords: p.keywords || p.tags?.join(', ')
};

// Format date
const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
};
---

<Base 
  title={pageTitle}
  description={p.metaDescription}
  ogImage={p.ogImage || p.image}
  canonicalUrl={p.canonicalUrl}
>
  {/* JSON-LD Structured Data */}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* Breadcrumb structured data */}
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": site?.url || "/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Field Notes",
          "item": `${site?.url || ''}/notes`
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": p.title + (p.titleEm ? ` ${p.titleEm}` : ''),
          "item": p.canonicalUrl || `${site?.url || ''}/notes/${post.slug}`
        }
      ]
    })}
  </script>

  {/* Article Header */}
  <article class="post-article">
    {/* Hero */}
    <header class="post-hero">
      <div class="post-hero-image">
        <img src={p.image} alt={p.imageAlt} />
        {p.imageCaption && <figcaption>{p.imageCaption}</figcaption>}
      </div>
      <div class="post-hero-content">
        <div class="container">
          <nav class="post-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span>/</span>
            <a href="/notes">Field Notes</a>
            <span>/</span>
            <span aria-current="page">{p.title}{p.titleEm && ` ${p.titleEm}`}</span>
          </nav>
          
          <div class="post-meta">
            <span class="post-category">{p.category}</span>
            <time datetime={p.publishDate}>{formatDate(p.publishDate)}</time>
            {p.updatedDate && p.updatedDate !== p.publishDate && (
              <span class="post-updated">Updated {formatDate(p.updatedDate)}</span>
            )}
          </div>
          
          <h1 class="post-title">
            {p.title}{p.titleEm && <em> {p.titleEm}</em>}
          </h1>
          
          {p.subtitle && <p class="post-subtitle">{p.subtitle}</p>}
          
          <p class="post-excerpt">{p.excerpt}</p>
          
          {p.tags && p.tags.length > 0 && (
            <div class="post-tags">
              {p.tags.map(tag => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </header>

    {/* Article Body */}
    <div class="post-body">
      <div class="container">
        {/* Main Content Column */}
        <div class="post-main">
          <div class="post-content">
            {/* Render MDX content */}
            <Content />
          </div>

          {/* Author / Footer */}
          <footer class="post-footer">
            <div class="post-author">
              <span>By {p.author}</span>
            </div>
          </footer>
        </div>

        {/* Related Posts — Full width below */}
        {relatedPosts.length > 0 && (
          <aside class="post-related" aria-label="Related articles">
            <h2>Related Field Notes</h2>
            <div class="related-grid">
              {relatedPosts.map(related => (
                <a href={`/notes/${related.slug}`} class="related-card">
                  <img src={related.data.image} alt={related.data.imageAlt} loading="lazy" />
                  <h3>{related.data.title}{related.data.titleEm && <em> {related.data.titleEm}</em>}</h3>
                  <p>{related.data.excerpt}</p>
                </a>
              ))}
            </div>
          </aside>
        )}
      </div>
    </div>
  </article>

</Base>

<style>
  /* Post Article Layout — Full width with generous reading column */
  .post-article {
    --content-width: 720px;
  }

  /* Hero — Full bleed with overlay */
  .post-hero {
    position: relative;
    background: var(--moss);
    color: var(--paper);
  }

  .post-hero-image {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 500px;
    max-height: 800px;
    overflow: hidden;
  }

  .post-hero-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(26, 46, 32, 0.2) 0%,
      rgba(26, 46, 32, 0.1) 40%,
      rgba(26, 46, 32, 0.85) 100%
    );
  }

  .post-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-hero-image figcaption {
    position: absolute;
    bottom: 1.5rem;
    right: 2rem;
    font-size: 0.8rem;
    font-style: italic;
    color: var(--paper);
    opacity: 0.8;
    z-index: 2;
  }

  .post-hero-content {
    padding: 3rem 0 5rem;
  }

  .post-hero-content .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Breadcrumb */
  .post-breadcrumb {
    font-family: var(--sans-fn);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2.5rem;
    opacity: 0.7;
  }

  .post-breadcrumb a {
    color: var(--ochre);
    transition: opacity 0.2s;
  }

  .post-breadcrumb a:hover {
    opacity: 1;
    color: var(--paper);
  }

  .post-breadcrumb span {
    margin: 0 0.5rem;
    opacity: 0.5;
  }

  /* Meta */
  .post-meta {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 2rem;
    font-family: var(--sans-fn);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .post-category {
    color: var(--ochre);
    font-weight: 500;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--ochre);
    opacity: 0.9;
  }

  .post-updated {
    opacity: 0.6;
  }

  /* Title */
  .post-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    line-height: 1.05;
    color: var(--paper);
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .post-title em {
    color: var(--ochre);
    font-style: italic;
  }

  .post-subtitle {
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    font-style: italic;
    color: var(--ochre);
    margin-bottom: 1.75rem;
    line-height: 1.4;
    opacity: 0.95;
  }

  .post-excerpt {
    font-size: 1.15rem;
    line-height: 1.65;
    opacity: 0.85;
    margin-bottom: 2rem;
    max-width: 55ch;
  }

  /* Tags */
  .post-tags {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .post-tag {
    font-family: var(--sans-fn);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.4rem 0.9rem;
    border: 1px solid rgba(250, 250, 245, 0.25);
    color: var(--paper);
    opacity: 0.75;
    transition: all 0.2s;
  }

  .post-tag:hover {
    opacity: 1;
    border-color: rgba(250, 250, 245, 0.5);
  }

  /* Body — Single column layout */
  .post-body {
    padding: 5rem 0 8rem;
    background: var(--paper);
  }

  .post-body .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .post-content {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--shadow);
  }

  .post-content h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin: 3.5rem 0 1.25rem;
    color: var(--moss);
    line-height: 1.2;
    font-weight: 500;
  }

  .post-content h2:first-child {
    margin-top: 0;
  }

  .post-content h3 {
    font-size: 1.35rem;
    margin: 2.5rem 0 1rem;
    color: var(--moss);
    font-weight: 500;
  }

  .post-content p {
    margin-bottom: 1.75rem;
    color: var(--shadow);
  }

  .post-content p:first-of-type::first-letter {
    font-family: var(--serif-display);
    font-size: 4.2rem;
    line-height: 0.85;
    float: left;
    color: var(--forest);
    margin: 0.25rem 0.5rem 0 0;
    font-weight: 400;
  }

  .post-content blockquote {
    margin: 2.5rem 0;
    padding: 2rem 2.5rem;
    border-left: 4px solid var(--forest);
    background: var(--leaf);
    font-style: italic;
    position: relative;
  }

  .post-content blockquote::before {
    content: '"';
    font-family: var(--serif-display);
    font-size: 4rem;
    color: var(--sage);
    opacity: 0.3;
    position: absolute;
    top: 0.5rem;
    left: 1rem;
    line-height: 1;
  }

  .post-content blockquote p {
    margin-bottom: 1rem;
    font-size: 1.25rem;
    color: var(--moss);
    line-height: 1.5;
    position: relative;
    z-index: 1;
  }

  .post-content blockquote cite {
    font-family: var(--sans-fn);
    font-size: 0.8rem;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sage);
    display: block;
    margin-top: 0.5rem;
  }

  .post-content ul,
  .post-content ol {
    margin: 1.5rem 0 2rem;
    padding-left: 1.75rem;
  }

  .post-content li {
    margin-bottom: 0.75rem;
    color: var(--shadow);
    line-height: 1.6;
  }

  .post-content strong {
    color: var(--moss);
    font-weight: 600;
  }

  .post-content em {
    color: var(--forest);
  }

  .post-content a {
    color: var(--forest);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--sage);
    transition: all 0.2s;
  }

  .post-content a:hover {
    color: var(--moss);
    text-decoration-color: var(--moss);
  }

  .post-figure {
    margin: 2.5rem 0;
  }

  .post-figure img {
    width: 100%;
    border-radius: 4px;
  }

  .post-figure figcaption {
    font-size: 0.9rem;
    font-style: italic;
    color: var(--sage);
    margin-top: 0.75rem;
    text-align: center;
  }

  /* Footer */
  .post-footer {
    margin-top: 5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .post-author {
    font-family: var(--sans-fn);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sage);
  }

  /* Related Posts — Full width below content */
  .post-related {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--rule);
    grid-column: 1 / -1;
  }

  .post-related h2 {
    font-size: 1.6rem;
    margin-bottom: 2rem;
    color: var(--moss);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .related-card {
    display: block;
    text-decoration: none;
    transition: transform 0.3s;
  }

  .related-card:hover {
    transform: translateY(-4px);
  }

  .related-card img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .related-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--moss);
    line-height: 1.25;
  }

  .related-card h3 em {
    color: var(--forest);
    font-style: italic;
  }

  .related-card p {
    font-size: 0.9rem;
    color: var(--shadow);
    line-height: 1.5;
  }

  .related-card:hover h3 {
    color: var(--forest);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .post-body .container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .post-hero-image {
      height: 50vh;
      min-height: 300px;
    }

    .post-hero-content {
      padding: 2rem 0 3rem;
    }

    .post-hero-content .container {
      padding: 0 1.5rem;
    }

    .post-body {
      padding: 3rem 0 5rem;
    }

    .post-body .container {
      padding: 0 1.5rem;
    }

    .post-content {
      font-size: 1.05rem;
    }

    .post-content p:first-of-type::first-letter {
      font-size: 3.5rem;
    }

    .post-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
